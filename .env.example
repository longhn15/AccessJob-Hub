# Frontend
FRONTEND_PORT=3000
VITE_DEV_PORT=5173
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8080

# Backend
BACKEND_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MySQL (Docker Compose — đổi password trước khi deploy thật)
MYSQL_DATABASE=accessjobhub
MYSQL_USER=accessjob
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Spring datasource (backend connect qua service name mysql trong Docker)
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/accessjobhub?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=accessjob
SPRING_DATASOURCE_PASSWORD=change-me

# Chỉ bật khi cần debug DB từ host
# MYSQL_PORT=3306
