# Frontend — AccessJob Hub
# Sao chép thành `.env` trong thư mục frontend khi chạy `npm run dev` độc lập.

# api = gọi backend thật (mặc định Docker/full-stack)
# mock = dữ liệu tĩnh cho GitHub Pages demo
VITE_DATA_SOURCE=api

VITE_DEV_PORT=5173
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8080
